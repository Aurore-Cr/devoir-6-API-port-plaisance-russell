<%- include('../components/header', { title: 'Réservations' }) %>

<div class="page-header">
  <h1> Toutes les réservations</h1>
  <a href="/catways" class="btn btn-primary">+ Nouvelle réservation</a>
</div>

<div class="alert alert-info">
   Pour créer une réservation, sélectionnez d'abord un catway.
  <a href="/catways">Voir les catways →</a>
</div>

<% if (locals.error) { %>
  <div class="alert alert-error"> <%= error %></div>
<% } %>

<div class="card">
  <table class="table">
    <thead>
      <tr>
        <th>Catway</th>
        <th>Client</th>
        <th>Bateau</th>
        <th>Début</th>
        <th>Fin</th>
        <th>Statut</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% if (reservations.length === 0) { %>
        <tr>
          <td colspan="7" class="empty-state">Aucune réservation enregistrée.</td>
        </tr>
      <% } %>
      <%
        const today = new Date();
        reservations.forEach(r => {
          const start = new Date(r.startDate);
          const end   = new Date(r.endDate);
          let statut, statutClass;
          if (today < start)      { statut = "À venir";  statutClass = "badge-upcoming"; }
          else if (today > end)   { statut = "Terminée"; statutClass = "badge-done"; }
          else                    { statut = "En cours"; statutClass = "badge-active"; }
      %>
      <tr>
        <td><strong>#<%= r.catwayNumber %></strong></td>
        <td><%= r.clientName %></td>
        <td><%= r.boatName %></td>
        <td><%= start.toLocaleDateString('fr-FR') %></td>
        <td><%= end.toLocaleDateString('fr-FR') %></td>
        <td><span class="badge <%= statutClass %>"><%= statut %></span></td>
        <td class="actions">
          <a href="/catways/<%= r.catwayNumber %>/reservations/<%= r._id %>"
             class="btn btn-sm btn-secondary">Détails</a>
          <a href="/catways/<%= r.catwayNumber %>/reservations/<%= r._id %>/edit"
             class="btn btn-sm btn-warning">Modifier</a>
          <form action="/catways/<%= r.catwayNumber %>/reservations/<%= r._id %>/delete"
                method="POST" style="display:inline"
                onsubmit="return confirm('Supprimer cette réservation ?')">
            <button type="submit" class="btn btn-sm btn-danger">Supprimer</button>
          </form>
        </td>
      </tr>
      <% }) %>
    </tbody>
  </table>
</div>

<%- include('../components/footer') %>
