<%- include('../components/header', { title: 'Nouveau catway' }) %>

<div class="page-header">
  <h1>⚓ Nouveau catway</h1>
  <a href="/catways" class="btn btn-secondary">← Retour</a>
</div>

<% if (error) { %>
  <div class="alert alert-error"> <%= error %></div>
<% } %>

<div class="card form-card">
  <form action="/catways" method="POST">
    <div class="form-group">
      <label for="catwayNumber">Numéro de catway *</label>
      <input type="number" id="catwayNumber" name="catwayNumber" min="1" required>
    </div>
    <div class="form-group">
      <label for="catwayType">Type *</label>
      <select id="catwayType" name="catwayType" required>
        <option value="">-- Choisir un type --</option>
        <option value="short">Short</option>
        <option value="long">Long</option>
      </select>
    </div>
    <div class="form-group">
      <label for="catwayState">État *</label>
      <textarea id="catwayState" name="catwayState" rows="3"
        placeholder="Description de l'état du catway..." required></textarea>
    </div>
    <div class="form-actions">
      <button type="submit" class="btn btn-primary">Créer le catway</button>
      <a href="/catways" class="btn btn-secondary">Annuler</a>
    </div>
  </form>
</div>

<%- include('../components/footer') %>
