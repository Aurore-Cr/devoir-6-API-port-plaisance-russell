<%- include('../components/header', { title: 'Catway #' + catway.catwayNumber }) %>

<div class="page-header">
  <h1>Catway #<%= catway.catwayNumber %></h1>
  <div class="btn-group">
    <a href="/catways/<%= catway.catwayNumber %>/edit" class="btn btn-warning"> Modifier</a>
    <a href="/catways" class="btn btn-secondary">← Retour</a>
  </div>
</div>

<div class="grid-2">
  <div class="card">
    <div class="card-header"><h2>Informations</h2></div>
    <dl class="info-list">
      <dt>Numéro</dt>
      <dd><strong>#<%= catway.catwayNumber %></strong></dd>
      <dt>Type</dt>
      <dd><span class="badge badge-<%= catway.catwayType %>"><%= catway.catwayType %></span></dd>
      <dt>État</dt>
      <dd><%= catway.catwayState %></dd>
    </dl>
  </div>

  <div class="card">
    <div class="card-header">
      <h2>Réservations</h2>
      <a href="/catways/<%= catway.catwayNumber %>/reservations/new"
         class="btn btn-sm btn-primary">+ Nouvelle</a>
    </div>
    <% if (reservations.length === 0) { %>
      <p class="empty-state">Aucune réservation pour ce catway.</p>
    <% } else { %>
    <table class="table">
      <thead>
        <tr><th>Client</th><th>Bateau</th><th>Début</th><th>Fin</th><th></th></tr>
      </thead>
      <tbody>
        <% reservations.forEach(r => { %>
        <tr>
          <td><%= r.clientName %></td>
          <td><%= r.boatName %></td>
          <td><%= new Date(r.startDate).toLocaleDateString('fr-FR') %></td>
          <td><%= new Date(r.endDate).toLocaleDateString('fr-FR') %></td>
          <td>
            <a href="/catways/<%= catway.catwayNumber %>/reservations/<%= r._id %>"
               class="btn btn-sm btn-secondary">Voir</a>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
    <% } %>
  </div>
</div>

<%- include('../components/footer') %>
