<%- include('components/header', { title: 'Dashboard' }) %>

<div class="dashboard-hero">
  <div class="dashboard-info">
    <h1>Tableau de bord</h1>
    <div class="dashboard-meta">
      <span> <strong><%= user.username %></strong> — <%= user.email %></span>
      <span> <%= new Date().toLocaleDateString('fr-FR', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' }) %></span>
    </div>
  </div>
  <div class="dashboard-actions">
    <a href="/catways" class="dash-card-link">
      <div class="dash-card">
       
        <span>Catways</span>
      </div>
    </a>
    <a href="/reservations" class="dash-card-link">
      <div class="dash-card">
        
        <span>Réservations</span>
      </div>
    </a>
    <a href="/users" class="dash-card-link">
      <div class="dash-card">
       
        <span>Utilisateurs</span>
      </div>
    </a>
    <a href="/docs" class="dash-card-link">
      <div class="dash-card">
        
        <span>Documentation</span>
      </div>
    </a>
  </div>
</div>

<div class="card">
  <div class="card-header">
    <h2> Réservations en cours</h2>
    <span class="badge badge-active"><%= reservations.length %> active<%= reservations.length > 1 ? 's' : '' %></span>
  </div>
  <% if (reservations.length === 0) { %>
    <p class="empty-state">Aucune réservation en cours aujourd'hui.</p>
  <% } else { %>
  <table class="table">
    <thead>
      <tr>
        <th>Catway</th>
        <th>Client</th>
        <th>Bateau</th>
        <th>Début</th>
        <th>Fin</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% reservations.forEach(r => { %>
      <tr>
        <td><strong>#<%= r.catwayNumber %></strong></td>
        <td><%= r.clientName %></td>
        <td><%= r.boatName %></td>
        <td><%= new Date(r.startDate).toLocaleDateString('fr-FR') %></td>
        <td><%= new Date(r.endDate).toLocaleDateString('fr-FR') %></td>
        <td>
          <a href="/catways/<%= r.catwayNumber %>/reservations/<%= r._id %>"
             class="btn btn-sm btn-secondary">Détails</a>
        </td>
      </tr>
      <% }) %>
    </tbody>
  </table>
  <% } %>
</div>

<%- include('components/footer') %>
