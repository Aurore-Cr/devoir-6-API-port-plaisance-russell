<%- include('../components/header', { title: 'Modifier ' + foundUser.username }) %>

<div class="page-header">
  <h1> Modifier <%= foundUser.username %></h1>
  <a href="/users/<%= foundUser.email %>" class="btn btn-secondary">← Retour</a>
</div>

<% if (error) { %>
  <div class="alert alert-error"> <%= error %></div>
<% } %>

<div class="card form-card">
  <form action="/users/<%= foundUser.email %>/edit" method="POST">
    <div class="form-group">
      <label for="username">Nom d'utilisateur *</label>
      <input type="text" id="username" name="username"
        value="<%= foundUser.username %>" required>
    </div>
    <div class="form-group">
      <label for="email">Adresse e-mail *</label>
      <input type="email" id="email" name="email"
        value="<%= foundUser.email %>" required>
    </div>
    <div class="form-group">
      <label for="password">
        Nouveau mot de passe
        <small>(laisser vide pour ne pas changer)</small>
      </label>
      <input type="password" id="password" name="password"
        minlength="6" placeholder="••••••">
    </div>
    <div class="form-actions">
      <button type="submit" class="btn btn-primary">Enregistrer</button>
      <a href="/users/<%= foundUser.email %>" class="btn btn-secondary">Annuler</a>
    </div>
  </form>
</div>

<%- include('../components/footer') %>
